-- ==========================================
-- DATA ANALYTICS DASHBOARD DATABASE
-- ==========================================

-- Create Table

CREATE TABLE sales (
    id SERIAL PRIMARY KEY,
    product VARCHAR(100) NOT NULL,
    category VARCHAR(50) NOT NULL,
    amount DECIMAL(10,2) NOT NULL,
    quantity INT NOT NULL,
    sale_date DATE NOT NULL
);

